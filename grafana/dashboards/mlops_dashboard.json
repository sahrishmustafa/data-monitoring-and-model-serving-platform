{
  "title": "MLOps Monitoring Dashboard",
  "uid": "mlops-2026",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Model Accuracy Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "model_accuracy",
          "legendFormat": "Accuracy"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Records Processed Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(records_processed_total[1m])",
          "legendFormat": "Records/sec"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Retrain Count",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        { "expr": "retrain_count_total" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Distribution Drift Detected",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        { "expr": "distribution_drift_detected" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "OK" }, "1": { "text": "DRIFT" } }, "type": "value" }
          ],
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Data Lake Unavailable Count",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        { "expr": "datalake_unavailable_total" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "P95 Response Latency (seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(response_delay_seconds_bucket[5m]))",
          "legendFormat": "P95 Latency"
        }
      ]
    }
  ]
}
